# Produktions-Umgebungsvariablen für ba-projekte.
# Diese Datei ins Repo committen – KEINE echten Secrets hier eintragen.
# Auf dem Server: cp .env.docker.dist .env.docker und Secrets ausfüllen.
#
# Berechtigungen nach dem Befüllen setzen: chmod 600 .env.docker

# ─── Symfony ──────────────────────────────────────────────────────────────────
APP_ENV=prod
# Mindestens 32 zufällige Zeichen – generieren: openssl rand -hex 32
APP_SECRET=CHANGE_ME

# ─── Docker-Images ────────────────────────────────────────────────────────────
# GitHub-Org / Username der GHCR-Images anpassen.
PHP_IMAGE=ghcr.io/byte-artist/ba-projekte-php
NGINX_IMAGE=ghcr.io/byte-artist/ba-projekte-nginx
IMAGE_TAG=latest

# ─── nginx Port ───────────────────────────────────────────────────────────────
HTTP_PORT=8050
