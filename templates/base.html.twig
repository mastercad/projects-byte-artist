<!DOCTYPE html>
<html lang="de">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="description" content="{% block meta_description %}Projektdokumentation und HowTos — byte-artist.de{% endblock %}">
        <title>{% block title %}Projekte | byte-artist.de{% endblock %}</title>
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">
        {% endblock %}
        <link rel="stylesheet"
              href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
              integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
              crossorigin="anonymous" referrerpolicy="no-referrer">
        <link rel="stylesheet"
              href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/atom-one-dark.min.css"
              crossorigin="anonymous">
    </head>
    <body>
        <nav class="site-nav" id="site-nav">
            <div class="nav-inner">
                <a class="nav-logo" href="{{ path('home') }}">
                    byte-artist
                    <span class="nav-logo-sub">/ projekte</span>
                </a>

                <ul class="nav-links">
                    <li><a href="{{ path('home') }}"{% if app.request.attributes.get('_route') == 'home' %} class="active"{% endif %}>Übersicht</a></li>
                    {% block nav_extra %}{% endblock %}
                </ul>

                <a class="nav-back" href="https://byte-artist.de" target="_blank" rel="noopener">
                    <i class="fas fa-arrow-left"></i>
                    byte-artist.de
                </a>

                <button class="hamburger" id="nav-toggle" aria-label="Navigation öffnen">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <footer class="site-footer">
            <div class="footer-inner">
                <span class="footer-brand">byte-artist / projekte</span>
                <nav class="footer-links" aria-label="Footer Navigation">
                    <a href="https://byte-artist.de/imprint" target="_blank" rel="noopener">Impressum</a>
                    <a href="https://byte-artist.de/data-protection" target="_blank" rel="noopener">Datenschutz</a>
                    <a href="https://byte-artist.de" target="_blank" rel="noopener">byte-artist.de</a>
                </nav>
                <span class="footer-copy">© {{ "now"|date("Y") }} Andreas — Open Source mit ♥</span>
            </div>
        </footer>

        {% block javascripts %}
            <script src="{{ asset('assets/js/app.js') }}" defer></script>
        {% endblock %}
        <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"
                crossorigin="anonymous"></script>
    </body>
</html>
