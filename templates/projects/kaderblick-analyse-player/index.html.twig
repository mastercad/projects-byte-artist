    { os: 'macos',   label: 'macOS — Apple Silicon (.dmg)',      url: 'https://github.com/mastercad/Kaderblick-Analyse-Player/releases/latest/download/kaderblick-analyse-player-mac-arm64.dmg',             type: 'installer', size: '207 MB' },
    { os: 'linux',   label: 'Linux — AppImage (alle Distros)',   url: 'https://github.com/mastercad/Kaderblick-Analyse-Player/releases/latest/download/kaderblick-analyse-player-linux-x86_64.AppImage',    type: 'portable',  size: '223 MB' },
    { os: 'linux',   label: 'Linux — .deb (Debian / Ubuntu)',    url: 'https://github.com/mastercad/Kaderblick-Analyse-Player/releases/latest/download/kaderblick-analyse-player-linux-amd64.deb',          type: 'installer', size: '175 MB' },
