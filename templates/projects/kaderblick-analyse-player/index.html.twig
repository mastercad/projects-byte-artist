{% extends 'projects/_base-project.html.twig' %}

{% set project = {
    tagline:  'Fußball-Videos gemeinsam analysieren — Szenen anspringen, Filter anwenden, Session sichern',
    icon_img: '/assets/img/kaderblick-analyse-player/kaderblick_analyse_player_appicon.svg',
    docs_url: null,
    intro:    'Der Kaderblick Analyse Player ist ein Desktop-Programm für die gemeinsame Videoanalyse im Team. Ihr ladet eure Spielvideos und eine CSV-Segmentdatei — und könnt mit einem Klick direkt zu jeder gespeicherten Szene springen. Live-Filter, Segmentmodus, Einzelwiederholung und ein eingebauter Segment-Editor machen aus der Spielvideo-Besprechung eine professionelle Trainingseinheit — ohne IT-Kenntnisse, ohne Installation.'
} %}

