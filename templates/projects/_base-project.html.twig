{% extends 'base.html.twig' %}

{#
  registryProject (vom Controller) ist die einzige Quelle für:
  slug, title, tags, status, github_url, icon
  Das Child-Template definiert nur: tagline, intro, docs_url, links
#}
{% set project = (project ?? {})|merge(registryProject ?? {}) %}

{% block title %}{{ project.title }} | byte-artist.de{% endblock %}
{% block meta_description %}{{ project.tagline ?? project.title }}{% endblock %}

{% block nav_extra %}
    <li><a href="{{ path('home') }}">← Alle Projekte</a></li>
{% endblock %}

{% block body %}
<main class="page-main">

    {# ── Hero ── #}
    {% include 'projects/_partials/_hero.html.twig' with { hero: project } %}

    <div class="page-content">
        <div class="doc-layout">

            {# ────────────────── HAUPTINHALT ────────────────── #}
            <div class="doc-content">

                {# ── Einleitung — optional; wird nur gerendert wenn project.intro gesetzt ist ── #}
                {% if project.intro is defined and project.intro %}
                <div class="prose">
                    <h2 id="overview">Überblick</h2>
                    <p>{{ project.intro }}</p>
                </div>
                {% endif %}

                {# ── Content-Blöcke — die Child-Template steuert die Reihenfolge vollständig ── #}
                {% block doc_content %}{% endblock %}

                {# ── Prev / Next Navigation ── #}
                {% if nav is defined and nav %}
                    <nav class="doc-nav" aria-label="Seitennavigation">
                        {% if nav.prev is defined and nav.prev %}
                            <a class="doc-nav-item doc-nav-item--prev" href="{{ path('project', { slug: nav.prev.slug }) }}">
                                <span class="doc-nav-label">← Vorheriges Projekt</span>
                                <span class="doc-nav-title">{{ nav.prev.title }}</span>
                            </a>
                        {% else %}
                            <div></div>
                        {% endif %}
                        {% if nav.next is defined and nav.next %}
                            <a class="doc-nav-item doc-nav-item--next" href="{{ path('project', { slug: nav.next.slug }) }}">
                                <span class="doc-nav-label">Nächstes Projekt →</span>
                                <span class="doc-nav-title">{{ nav.next.title }}</span>
                            </a>
                        {% endif %}
                    </nav>
                {% endif %}

            </div>
            {# /doc-content #}

            {# ────────────────── TOC ────────────────── #}
            {% if toc is defined and toc %}
                <aside class="doc-toc">
                    <p class="doc-toc-title">Inhalt</p>
                    <ul class="doc-toc-list">
                        {% for item in toc %}
                            <li class="doc-toc-item{% if item.sub is defined and item.sub %} doc-toc-item--sub{% endif %}">
                                <a href="#{{ item.id }}">{{ item.label }}</a>
                            </li>
                        {% endfor %}
                    </ul>
                </aside>
            {% endif %}

        </div>
    </div>

</main>
{% endblock %}
