{% extends 'projects/_base-project.html.twig' %}

{#
  Beispiel-Projektseite — zeigt alle verfügbaren Partials und Komponenten.
  Dient als Vorlage für neue Projekte: kopieren → umbenennen → Inhalte ersetzen.

  Dieses Beispiel simuliert ein plattformübergreifendes Desktop-Tool in C++/Qt,
  das als Installer und portable Version für Windows, Linux und macOS verfügbar ist.
  So wird deutlich, dass das System NICHT auf Web-/PHP-/Composer-Projekte beschränkt ist.

  ── Bildpfade ──────────────────────────────────────────────────────────────
  Die verwendeten Bildpfade sind Platzhalter. Eigene Screenshots ablegen unter
  public/assets/img/<projekt-slug>/ und src-Werte entsprechend anpassen.
  ──────────────────────────────────────────────────────────────────────────
#}

{% set project = {
    tagline:    'Leistungsstarkes Batch-Dateitransformations-Tool für Windows, Linux und macOS — zusammenführen, konvertieren und umbenennen in einem Durchgang.',
    docs_url:   null,
} %}

{% set toc = [
    { id: 'overview',      label: 'Überblick' },
    { id: 'downloads',     label: 'Downloads' },
    { id: 'features',      label: 'Features' },
    { id: 'screenshots',   label: 'Screenshots' },
    { id: 'tech-stack',    label: 'Tech-Stack' },
    { id: 'installation',  label: 'Installation / Build' },
    { id: 'usage',         label: 'Verwendung' },
    { id: 'demo',          label: 'Demo-Video' },
] %}

{% set features = [
    { icon: 'fas fa-layer-group',   title: 'Batch-Verarbeitung',     desc: 'Hunderte Dateien in einem Durchgang transformieren — mit Live-Vorschau der Ergebnisse vor dem Ausführen.' },
    { icon: 'fas fa-rotate',        title: 'Format-Konvertierung',   desc: 'Konvertierung zwischen gängigen Formaten (Bilder, Text, CSV, JSON, XML) direkt ohne externe Tools.' },
    { icon: 'fas fa-i-cursor',      title: 'Intelligentes Umbenennen', desc: 'Regelbasiertes Umbenennen mit Mustern, Nummerierung, Datum, EXIF-Metadaten und Regex-Unterstützung.' },
    { icon: 'fas fa-code-merge',    title: 'Datei-Merge',            desc: 'Mehrere Dateien gleichen Typs (CSV, TXT, JSON-Arrays) zu einer Ausgabedatei zusammenführen.' },
    { icon: 'fas fa-terminal',      title: 'CLI-Modus',              desc: 'Vollständig per Kommandozeile steuerbar — ideal für Automatisierung in Skripten und CI-Pipelines.' },
    { icon: 'fas fa-puzzle-piece',  title: 'Plugin-System',          desc: 'Eigene Transformationen als C++-Plugin (shared library) einbinden — ohne das Hauptprogramm zu ändern.' },
    { icon: 'fas fa-earth-europe',  title: 'Cross-Platform',         desc: 'Nativer Build für Windows, Linux und macOS. Keine Wine-Schicht, keine VM, keine Einschränkungen.' },
    { icon: 'fas fa-box-open',      title: 'Portable & Installer',   desc: 'Steht als klassischer Installer und als portable Version ohne Installationsbedarf zur Verfügung.' },
] %}

{% set install_steps = [
    {
        title: 'Voraussetzungen installieren',
        text:  'CMake ≥ 3.25 und Qt 6.6 (mit Modulen Core, Widgets, Concurrent) werden vorausgesetzt. Unter Linux zusätzlich einen C++17-fähigen GCC oder Clang.',
        code:  { lang: 'bash', content: "# Ubuntu / Debian\nsudo apt install cmake gcc qt6-base-dev qt6-tools-dev\n\n# macOS (Homebrew)\nbrew install cmake qt6\n\n# Windows: Qt Online Installer + Visual Studio 2022 Build Tools" }
    },
    {
        title: 'Repository klonen und CMake konfigurieren',
        text:  'Das Projekt verwendet CMake mit vordefinierten Presets. Für Standard-Builds reicht das Release-Preset.',
        code:  { lang: 'bash', content: "git clone https://github.com/byte-artist/filefusion.git\ncd filefusion\ncmake --preset release" }
    },
    {
        title: 'Projekt bauen',
        text:  'Den Build parallel ausführen — parallele Jobs deutlich schneller als sequenziell.',
        code:  { lang: 'bash', content: "cmake --build build/release --parallel $(nproc)" }
    },
    {
        title: 'Optional: Paket / Installer erzeugen',
        text:  'CPack-Integration erstellt plattformspezifische Pakete (NSIS-Installer unter Windows, DEB/RPM unter Linux, DMG unter macOS).',
        code:  { lang: 'bash', content: "cd build/release\ncpack -G NSIS   # Windows → FileFusion-1.4.0-win64-installer.exe\ncpack -G DEB    # Debian/Ubuntu → filefusion_1.4.0_amd64.deb\ncpack -G DragNDrop  # macOS → FileFusion-1.4.0-macos.dmg" }
    },
] %}

{% block doc_content %}

    {# ── Downloads ── #}
    <div class="prose">
        <h2 id="downloads">Downloads</h2>
        <p>Vorkompilierte Pakete für alle Plattformen — einfach herunterladen und starten:</p>
    </div>

    {% include 'projects/_partials/_downloads.html.twig' with { downloads: [
        { os: 'windows', label: 'Windows 10/11 — Installer (64-bit)',   url: 'https://github.com/byte-artist/filefusion/releases/download/v1.4.0/FileFusion-1.4.0-win64-installer.exe', type: 'installer', size: '38 MB' },
        { os: 'windows', label: 'Windows 10/11 — Portable (.zip)',      url: 'https://github.com/byte-artist/filefusion/releases/download/v1.4.0/FileFusion-1.4.0-win64-portable.zip',  type: 'portable',  size: '35 MB' },
        { os: 'linux',   label: 'Linux — AppImage (x86_64)',            url: 'https://github.com/byte-artist/filefusion/releases/download/v1.4.0/FileFusion-1.4.0-x86_64.AppImage',      type: 'appimage',  size: '52 MB' },
        { os: 'linux',   label: 'Linux — DEB-Paket (Debian/Ubuntu)',    url: 'https://github.com/byte-artist/filefusion/releases/download/v1.4.0/filefusion_1.4.0_amd64.deb',           type: 'deb',       size: '18 MB' },
        { os: 'linux',   label: 'Linux — RPM-Paket (Fedora/openSUSE)',  url: 'https://github.com/byte-artist/filefusion/releases/download/v1.4.0/filefusion-1.4.0-1.x86_64.rpm',        type: 'rpm',       size: '19 MB' },
        { os: 'macos',   label: 'macOS 12+ — DMG (Universal Binary)',   url: 'https://github.com/byte-artist/filefusion/releases/download/v1.4.0/FileFusion-1.4.0-macos-universal.dmg', type: 'installer', size: '61 MB' },
        { os: 'source',  label: 'Quellcode (GitHub)',                   url: 'https://github.com/byte-artist/filefusion', type: 'source' },
    ] } %}

    {# ── Features ── #}
    <div class="prose">
        <h2 id="features">Features</h2>
    </div>
    {% include 'projects/_partials/_feature-grid.html.twig' with { features: features } %}

    {# ── Screenshots ── #}
    <div class="prose">
        <h2 id="screenshots">Screenshots</h2>
        <p>Einblick in die Oberfläche unter Windows und Linux:</p>
    </div>

    {% include 'projects/_partials/_screenshot.html.twig' with { screenshot: {
        src:     '/assets/img/beispiel-projekt/dashboard-overview.png',
        alt:     'FileFusion — Hauptfenster',
        caption: 'Das Hauptfenster mit Dateiliste, Transformationsregeln und Live-Vorschau der umbenannten Dateien.'
    } } %}

    {% include 'projects/_partials/_gallery.html.twig' with {
        cols: 3,
        images: [
            { src: '/assets/img/beispiel-projekt/screen-metrics.png',  alt: 'Batch-Umbenennen',   caption: 'Regelbasiertes Umbenennen mit Regex und Nummerierungsmustern' },
            { src: '/assets/img/beispiel-projekt/screen-traces.png',   alt: 'Format-Konverter',   caption: 'Konvertierung von CSV zu JSON mit Spalten-Mapping' },
            { src: '/assets/img/beispiel-projekt/screen-alerts.png',   alt: 'Plugin-Manager',     caption: 'Eigene Transformations-Plugins im Plugin-Manager verwalten' },
            { src: '/assets/img/beispiel-projekt/screen-team.png',     alt: 'CLI-Ausgabe',        caption: 'CLI-Modus für Batch-Automatisierung in Shell-Skripten' },
            { src: '/assets/img/beispiel-projekt/screen-service.png',  alt: 'Linux (Dark)',       caption: 'Native GTK-Integration unter Ubuntu mit Dark Mode' },
            { src: '/assets/img/beispiel-projekt/screen-darkmode.png', alt: 'macOS',              caption: 'macOS-Version mit nativer Menüleiste und Touch Bar Support' },
        ]
    } %}

    {# ── Tech-Stack ── #}
    <div class="prose">
        <h2 id="tech-stack">Tech-Stack</h2>
    </div>

    {% include 'projects/_partials/_tech-stack.html.twig' with { items: [
        { icon: 'fas fa-code',         name: 'C++17',         role: 'Sprache' },
        { icon: 'fas fa-q',            name: 'Qt 6.6',        role: 'UI-Framework',    color: '#41cd52' },
        { icon: 'fas fa-cube',         name: 'CMake 3.25',    role: 'Build-System' },
        { icon: 'fab fa-windows',      name: 'MSVC 2022',     role: 'Windows-Compiler',color: '#0078d4' },
        { icon: 'fab fa-linux',        name: 'GCC 13',        role: 'Linux-Compiler',  color: '#f0a500' },
        { icon: 'fab fa-apple',        name: 'Clang 16',      role: 'macOS-Compiler',  color: '#a2aab0' },
        { icon: 'fas fa-box',          name: 'CPack',         role: 'Paketierung' },
        { icon: 'fas fa-vial',         name: 'Catch2',        role: 'Unit-Tests' },
    ] } %}

    {# ── Installation / Build ── #}
    <div class="prose">
        <h2 id="installation">Installation / Build</h2>
        <p>Wer selbst bauen möchte oder auf eine nicht gelistete Plattform abzielt:</p>
    </div>
    {% include 'projects/_partials/_steps.html.twig' with { steps: install_steps } %}

    {% include 'projects/_partials/_callout.html.twig' with {
        type:  'tip',
        title: 'CMake-Presets',
        text:  'Das Repository enthält <code>CMakePresets.json</code> mit vorkonfigurierten Presets für
                Debug, Release und Package. In IDEs wie CLion oder VS Code werden sie automatisch erkannt.'
    } %}

    {% include 'projects/_partials/_callout.html.twig' with {
        type:  'info',
        title: 'Cross-Compilation',
        text:  'Für Windows-Builds unter Linux (z. B. in CI) steht ein MXE-basiertes Cross-Compile-Preset bereit.
                Details im <code>docs/cross-compile.md</code> im Repository.'
    } %}

    {# ── Verwendung ── #}
    <div class="prose">
        <h2 id="usage">Verwendung</h2>
        <h3>GUI-Modus</h3>
        <p>FileFusion starten, Dateien per Drag &amp; Drop einwerfen, Regeln definieren, Vorschau prüfen,
           dann mit <kbd>Strg+Enter</kbd> ausführen.</p>

        <h3>CLI-Modus</h3>
        <p>Mit dem <code>--headless</code>-Flag läuft FileFusion ohne GUI — ideal für Shell-Skripte
           und CI-Pipelines:</p>
    </div>

    {% include 'projects/_partials/_code-block.html.twig' with {
        lang: 'bash',
        content: '# Alle .csv-Dateien im Ordner zu JSON konvertieren\nfilefusion --headless convert --from csv --to json ./input/ --out ./output/\n\n# Batch-Umbenennen: Datum voranstellen\nfilefusion --headless rename --pattern "{date:Y-m-d}_{original}" ./fotos/'
    } %}

    {% include 'projects/_partials/_callout.html.twig' with {
        type:  'warning',
        title: 'Breaking Change in v1.4',
        text:  'Das Plugin-API wurde in v1.4 auf eine binärstabile ABI umgestellt.
                Plugins die gegen v1.3 gebaut wurden müssen neu kompiliert werden.'
    } %}

    {# ── Demo-Video ── #}
    <div class="prose">
        <h2 id="demo">Demo-Video</h2>
        <p>Kompletter Walkthrough — Installation bis zum ersten Batch-Job:</p>
    </div>

    {% include 'projects/_partials/_video.html.twig' with { video: {
        type:    'youtube',
        src:     'dQw4w9WgXcQ',
        title:   'FileFusion — vollständige Demo',
        caption: 'Ca. 8 Minuten — von der Installation bis zum ersten produktiven Batch-Lauf.'
    } } %}

{% endblock %}
