{% set project = {
    tagline:    'Echtzeit-Monitoring und Alerting für verteilte Symfony-Anwendungen — mit historischen Metriken, Trace-Visualisierung und Team-Benachrichtigungen.',
    docs_url:   null,
    intro: 'Chronos Dashboard ist eine selbst gehostete Monitoring-Plattform speziell für PHP-Anwendungen.
            Es sammelt Laufzeit-Metriken, visualisiert Request-Traces und verschickt smarte Alerts über
            Slack, E-Mail oder Webhooks — ohne externe Abhängigkeiten wie Datadog oder New Relic.'
} %}

