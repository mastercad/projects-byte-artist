{% set features = [
    { icon: 'fas fa-gauge-high',    title: 'Echtzeit-Metriken',       desc: 'CPU, Memory, DB-Queries, Cache-Hit-Rate und HTTP-Throughput — live im Browser per WebSocket.' },
    { icon: 'fas fa-route',         title: 'Request-Tracing',         desc: 'Distributed Tracing über mehrere Services mit Flamegraph-Visualisierung und SQL-Analyse.' },
    { icon: 'fas fa-bell',          title: 'Intelligentes Alerting',  desc: 'Regelbasierte Alerts mit konfigurierbaren Schwellenwerten, Cooldowns und Eskalationsstufen.' },
    { icon: 'fas fa-chart-line',    title: 'Historische Metriken',    desc: 'TimeSeries-Daten für bis zu 12 Monate mit frei konfigurierbaren Dashboards und Aggregationen.' },
    { icon: 'fas fa-users',         title: 'Team-Management',         desc: 'Rollen, Benachrichtigungsprofile und On-Call-Rotation direkt im Dashboard verwalten.' },
