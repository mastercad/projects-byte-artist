{% set install_steps = [
    {
        title: 'Repository klonen und Abhängigkeiten installieren',
        text:  'PHP 8.3+, Composer 2 und Docker (für PostgreSQL + Redis) werden vorausgesetzt.',
        code:  { lang: 'bash', content: "git clone https://github.com/byte-artist/chronos-dashboard.git\ncd chronos-dashboard\ncomposer install --no-dev --optimize-autoloader" }
    },
    {
        title: 'Umgebungsvariablen konfigurieren',
        text:  'Die .env.example in .env.local kopieren und Datenbankverbindung sowie App-Secret eintragen.',
        code:  { lang: 'bash', filename: '.env.local', content: "APP_ENV=prod\nAPP_SECRET=<sicherer-zufallsstring>\nDATABASE_URL=\"postgresql://chronos:secret@127.0.0.1:5432/chronos?serverVersion=16\"\nREDIS_URL=redis://127.0.0.1:6379\nMAILER_DSN=smtp://user:pass@smtp.example.com:587" }
    },
    {
        title: 'Datenbank initialisieren und Assets bauen',
        text:  'Migrations ausführen und den initialen Admin-Account anlegen.',
        code:  { lang: 'bash', content: "php bin/console doctrine:migrations:migrate --no-interaction\nphp bin/console chronos:admin:create admin@example.com\nnpm ci && npm run build" }
    },
    {
        title: 'Mit Docker Compose starten (optional)',
        text:  'Alternativ steht ein vollständiges Docker-Compose-Setup bereit, das PostgreSQL, Redis und den PHP-FPM-Container orchestriert.',
        code:  { lang: 'bash', content: "docker compose up -d\ndocker compose exec app php bin/console doctrine:migrations:migrate --no-interaction" }
    },
] %}

{% set config_rows = [
    { option: 'retention_days',      type: 'int',     default: '90',     desc: 'Wie viele Tage Metriken aufbewahrt werden. Höhere Werte brauchen mehr Disk-Space.' },
    { option: 'sampling_rate',       type: 'float',   default: '1.0',    desc: 'Anteil der Requests der getraced wird. 0.1 = 10 %, empfohlen für High-Traffic.' },
    { option: 'alert_cooldown',      type: 'int',     default: '300',    desc: 'Mindestabstand zwischen zwei Alerts gleicher Regel in Sekunden.' },
    { option: 'websocket_port',      type: 'int',     default: '9001',   desc: 'Port des integrierten Ratchet-WebSocket-Servers.' },
    { option: 'slack_webhook_url',   type: 'string',  default: 'null',   desc: 'Slack Incoming Webhook URL für Alert-Benachrichtigungen.' },
    { option: 'sso_enabled',         type: 'bool',    default: 'false',  desc: 'SAML 2.0 / OIDC Single Sign-On aktivieren.' },
    { option: 'sso_provider_url',    type: 'string',  default: 'null',   desc: 'IdP-Metadaten-URL (nur relevant wenn sso_enabled = true).' },
    { option: 'max_services',        type: 'int',     default: '50',     desc: 'Maximale Anzahl registrierter Services pro Instanz.' },
] %}

{% block doc_content %}

    {# ── Kennzahlen ── #}
    <div class="prose">
        <h2 id="stats">Kennzahlen</h2>
        <p>Chronos Dashboard wurde in Produktionsumgebungen bei mehreren Teams getestet und validiert:</p>
    </div>

    {% include 'projects/_partials/_stats.html.twig' with { stats: [
        { value: '< 2ms',  label: 'SDK Overhead pro Request',  icon: 'fas fa-bolt' },
        { value: '99.9%',  label: 'Uptime (eigene Instanz)',    icon: 'fas fa-shield' },
        { value: '12 Mo',  label: 'Metriken-Retention',         icon: 'fas fa-database' },
        { value: '50+',    label: 'Services pro Instanz',       icon: 'fas fa-server' },
        { value: '< 5 Min',label: 'SDK-Integration',            icon: 'fas fa-plug' },
    ] } %}

    {# ── Architektur ── #}
    <div class="prose">
        <h2 id="architecture">Architektur</h2>
        <p>
            Das System besteht aus drei Schichten: dem PHP-SDK (in die eigene Anwendung eingebettet),
            einem zentralen Ingest-Service und dem Dashboard-Frontend. Daten fließen asynchron über
            eine Redis-Queue, sodass der Monitoring-Overhead die eigentliche Anwendung nicht blockiert.
        </p>
    </div>

    {% include 'projects/_partials/_media-text.html.twig' with {
        image: { src: '/assets/img/beispiel-projekt/architecture-diagram.png', alt: 'Chronos Architektur-Diagramm' },
        badge: 'Systemarchitektur',
        title: 'Asynchrone Metrik-Pipeline',
        text:  'Das PHP-SDK schreibt Metriken und Traces in einen lokalen In-Memory-Buffer und flushed
                diese am Request-Ende asynchron in eine Redis-Liste. Ein Symfony-Worker konsumiert die
                Queue, aggregiert die Rohdaten und persistiert sie in PostgreSQL — ohne den Response-Cycle
                der eigentlichen Anwendung zu blockieren.',
        points: [
            '<strong>PHP-SDK</strong> — Composer-Paket, kein Symfony-Bundle erforderlich',
            '<strong>Ingest Worker</strong> — Symfony Messenger Consumer, horizontal skalierbar',
            '<strong>TimeSeries Store</strong> — PostgreSQL mit TimescaleDB Extension',
            '<strong>Realtime Layer</strong> — Ratchet WebSocket Server für Live-Metriken',
            '<strong>Alert Engine</strong> — regelbasiert mit konfigurierbarem Cooldown und Routing',
        ]
    } %}

    {% include 'projects/_partials/_media-text.html.twig' with {
        image: { src: '/assets/img/beispiel-projekt/alert-flow.png', alt: 'Alert-Flow Diagramm' },
        badge: 'Alerting',
        title: 'Smarte Alert-Logik',
        text:  'Die Alert Engine evaluiert Regeln in konfigurierbaren Intervallen. Alerts werden erst
                ausgelöst wenn eine Bedingung für mehrere aufeinanderfolgende Checks erfüllt ist
                ("for duration") — das eliminiert False Positives durch kurzfristige Spitzen.',
        points: [
            'Schwellenwert-Regeln für jede Metrik konfigurierbar',
            'Cooldown verhindert Alert-Flooding',
            'Eskalationsstufen: Slack → E-Mail → PagerDuty-Webhook',
            'Stille-Fenster für geplante Wartungen',
        ],
        flip: true
    } %}

