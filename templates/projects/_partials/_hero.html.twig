{#
  Partial: _hero.html.twig
  Verwendung: {% include 'projects/_partials/_hero.html.twig' with { hero: {...} } %}

  hero = {
    title:       string,
    tagline:     string,
    status:      'stable'|'beta'|'wip',
    tags:        string[],
    github_url:  string|null,   – Shortcut: rendert einen GitHub-Button (secondary)
    docs_url:    string|null,   – Shortcut: rendert einen Dokumentations-Button (primary)
    links:       [              – Beliebige weitere Buttons (optional)
      { label: string, url: string, icon: string|null, style: 'primary'|'secondary'|'outline', extern: bool }
    ]
  }
#}
<header class="page-hero">
    <div class="page-hero-inner">
        <div class="page-hero-meta">
            <span class="status-badge status-badge--{{ hero.status }}">{{ hero.status }}</span>
            <div class="tags">
                {% for tag in hero.tags %}
                    <a class="tag" href="{{ path('home') }}?tag={{ tag|url_encode }}">{{ tag }}</a>
                {% endfor %}
            </div>
        </div>
        {% if hero.icon_img is defined and hero.icon_img %}
        <div class="page-hero-title-row">
            <img src="{{ hero.icon_img }}" alt="{{ hero.title }} Icon" class="page-hero-appicon">
            <h1>{{ hero.title }}</h1>
        </div>
        {% else %}
        <h1>{{ hero.title }}</h1>
        {% endif %}
        <p class="page-hero-desc">{{ hero.tagline }}</p>
        <div class="page-hero-meta mt-4">
            {% if hero.github_url is defined and hero.github_url %}
                <a class="btn-secondary" href="{{ hero.github_url }}" target="_blank" rel="noopener noreferrer">
                    <i class="fab fa-github"></i> GitHub
                </a>
            {% endif %}
            {% if hero.docs_url is defined and hero.docs_url %}
                <a class="btn-primary" href="{{ hero.docs_url }}">
                    <i class="fas fa-book-open"></i> Dokumentation
                </a>
            {% endif %}
            {% if hero.links is defined and hero.links %}
                {% for link in hero.links %}
                    <a class="btn-{{ link.style ?? 'secondary' }}"
                       href="{{ link.url }}"
                       {% if link.extern is defined and link.extern %}target="_blank" rel="noopener noreferrer"{% endif %}>
                        {% if link.icon is defined and link.icon %}<i class="{{ link.icon }}"></i> {% endif %}{{ link.label }}
                    </a>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</header>
