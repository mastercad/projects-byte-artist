{#
  Partial: _code-block.html.twig
  Verwendung: {% include 'projects/_partials/_code-block.html.twig' with { lang: 'bash', filename: 'composer.json', content: '...' } %}
#}
<div class="code-block">
    <div class="code-block-header">
        <span class="code-block-lang">
            <i class="fas fa-code"></i>
            {{ lang }}
            {% if filename is defined and filename %}&nbsp;·&nbsp; {{ filename }}{% endif %}
        </span>
        <button class="code-block-copy" type="button">
            <i class="fas fa-copy"></i> Kopieren
        </button>
    </div>
    <pre><code class="language-{{ lang }}">{{ content }}</code></pre>
</div>
